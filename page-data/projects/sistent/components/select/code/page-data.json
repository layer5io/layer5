{"componentChunkName":"component---src-templates-sistent-component-js-content-file-path-src-collections-sistent-components-select-code-mdx","path":"/projects/sistent/components/select/code","result":{"data":{"mdx":{"body":"\nimport { useState } from \"react\";\nimport { FormHelperText, Grid } from \"@mui/material\";\nimport { FormControl, Select, MenuItem, InputLabel, OutlinedInput, ListSubheader, Box } from \"@sistent/sistent\";\n\nexport const BasicSelectCodeDemo = ({ variant, ...props }) => {\n  return (\n    <FormControl sx={{ width: \"200px\" }} variant={variant} {...props}>\n      <Select MenuProps={{ disableScrollLock: true, marginThreshold: null }} defaultValue={10} {...props}>\n        <MenuItem value={10}>Ten</MenuItem>\n        <MenuItem value={20}>Twenty</MenuItem>\n        <MenuItem value={30}>Thirty</MenuItem>\n      </Select>\n    </FormControl>\n  );\n};\n\nexport const AutoWidthSelectCodeDemo = () => {\n  return (\n    <FormControl sx={{ minWidth: \"120px\" }}>\n      <Select MenuProps={{ disableScrollLock: true, marginThreshold: null }} defaultValue={10} autoWidth>\n        <MenuItem value={10}>Ten</MenuItem>\n        <MenuItem value={20}>Twenty</MenuItem>\n        <MenuItem value={30}>Thirty</MenuItem>\n      </Select>\n    </FormControl>\n  );\n};\n\nexport const FullWidthSelectCodeDemo = () => {\n  return (\n    <FormControl fullWidth>\n      <Select MenuProps={{ disableScrollLock: true, marginThreshold: null }} defaultValue={10} fullWidth>\n        <MenuItem value={10}>Ten</MenuItem>\n        <MenuItem value={20}>Twenty</MenuItem>\n        <MenuItem value={30}>Thirty</MenuItem>\n      </Select>\n    </FormControl>\n  );\n};\n\nexport const LabelSelectCodeDemo = () => {\n  return (\n    <FormControl sx={{ width: \"200px\" }}>\n      <InputLabel id=\"demo-select-label\">Age</InputLabel>\n      <Select MenuProps={{ disableScrollLock: true, marginThreshold: null }}\n        labelId=\"demo-select-label\"\n        id=\"demo-select\"\n        label=\"Age\"\n      >\n        <MenuItem value={10}>Ten</MenuItem>\n        <MenuItem value={20}>Twenty</MenuItem>\n        <MenuItem value={30}>Thirty</MenuItem>\n      </Select>\n    </FormControl>\n  );\n};\n\nexport const HelperSelectCodeDemo = () => {\n  return (\n    <FormControl sx={{ width: \"200px\" }}>\n      <Select MenuProps={{ disableScrollLock: true, marginThreshold: null }} defaultValue={10}>\n        <MenuItem value={10}>Ten</MenuItem>\n        <MenuItem value={20}>Twenty</MenuItem>\n        <MenuItem value={30}>Thirty</MenuItem>\n      </Select>\n      <FormHelperText>This is a helper text</FormHelperText>\n    </FormControl>\n  );\n};\n\nexport const PlaceholderSelectCodeDemo = () => {\n  const [selectedAge, setSelectedAge] = useState(\"\");\n  return (\n    <FormControl sx={{ width: \"200px\" }}>\n      <Select MenuProps={{ disableScrollLock: true, marginThreshold: null }}\n        id=\"demo-select-placeholder\"\n        onChange={(e) => setSelectedAge(e.target.value)}\n        renderValue={() => {\n          if (selectedAge == \"\") return <em>Select an age</em>;\n          return selectedAge;\n        }}\n        value={selectedAge}\n        displayEmpty\n      >\n        <MenuItem value={10}>Ten</MenuItem>\n        <MenuItem value={20}>Twenty</MenuItem>\n        <MenuItem value={30}>Thirty</MenuItem>\n      </Select>\n    </FormControl>\n  );\n};\n\nexport const GroupingSelectCodeDemo = () => {\n  return (\n    <FormControl sx={{ width: \"200px\" }}>\n      <Select MenuProps={{ disableScrollLock: true, marginThreshold: null }} defaultValue={10}>\n        <ListSubheader muiSkipListHighlight>Group 1</ListSubheader>\n        <MenuItem value={10}>Ten</MenuItem>\n        <MenuItem value={20}>Twenty</MenuItem>\n        <ListSubheader muiSkipListHighlight>Group 2</ListSubheader>\n        <MenuItem value={30}>Thirty</MenuItem>\n        <MenuItem value={40}>Fourty</MenuItem>\n        <ListSubheader muiSkipListHighlight>Group 3</ListSubheader>\n        <MenuItem value={50}>Fifty</MenuItem>\n        <MenuItem value={60}>Sixty</MenuItem>\n      </Select>\n    </FormControl>\n  );\n};\n\nexport const BehaviorSelectCodeDemo = () => {\n  return (\n    <Grid container spacing={2} sx={{ justifyContent: \"center\" }}>\n      <FormControl sx={{ width: \"200px\" }} disabled>\n        <Select MenuProps={{ disableScrollLock: true, marginThreshold: null }} defaultValue={10}>\n          <MenuItem value={10}>Ten</MenuItem>\n          <MenuItem value={20}>Twenty</MenuItem>\n          <MenuItem value={30}>Thirty</MenuItem>\n        </Select>\n      </FormControl>\n      <FormControl sx={{ width: \"200px\" }} error>\n        <Select MenuProps={{ disableScrollLock: true, marginThreshold: null }} defaultValue={10}>\n          <MenuItem value={10}>Ten</MenuItem>\n          <MenuItem value={20}>Twenty</MenuItem>\n          <MenuItem value={30}>Thirty</MenuItem>\n        </Select>\n      </FormControl>\n    </Grid>\n  );\n};\n\nexport const RequiredSelectCodeDemo = () => {\n  return (\n    <FormControl sx={{ width: \"200px\" }} required>\n      <InputLabel id=\"demo-select-label-required\">Age</InputLabel>\n      <Select MenuProps={{ disableScrollLock: true, marginThreshold: null }}\n        labelId=\"demo-select-label-required\"\n        id=\"demo-select-required\"\n        label=\"Age\"\n      >\n        <MenuItem value={10}>Ten</MenuItem>\n        <MenuItem value={20}>Twenty</MenuItem>\n        <MenuItem value={30}>Thirty</MenuItem>\n      </Select>\n    </FormControl>\n  );\n};\n\nexport const MultipleSelectCodeDemo = () => {\n  const [multipleAges, setMultipleAges] = useState([10]);\n  const handleMultiplSelect = (event) => {\n    setMultipleAges(event.target.value);\n  };\n  return (\n    <FormControl sx={{ width: \"200px\" }}>\n      <Select MenuProps={{ disableScrollLock: true, marginThreshold: null }}\n        multiple\n        input={<OutlinedInput label=\"Name\" />}\n        value={multipleAges}\n        onChange={handleMultiplSelect}\n      >\n        <MenuItem value={10}>Ten</MenuItem>\n        <MenuItem value={20}>Twenty</MenuItem>\n        <MenuItem value={30}>Thirty</MenuItem>\n      </Select>\n    </FormControl>\n  );\n};\n\n\n<a id=\"Select variants\">\n  <h2>Select variants</h2>\n</a>\n<p>\n  The select comes in three types: Outlined, Filled, and Standard. To\n  specify the variant, pass a value to the variant prop.\n</p>\n\n<h3>Outlined</h3>\n<p>\n  If not specified, the default variant of the select if outlined.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <BasicSelectCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"outlined-selection\" collapsible code={`<Select>\n  <MenuItem value={10}>Ten</MenuItem>\n  <MenuItem value={20}>Twenty</MenuItem>\n  <MenuItem value={30}>Thirty</MenuItem>\n</Select>`} />\n</div>\n\n<h3>Filled</h3>\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <BasicSelectCodeDemo variant=\"filled\" />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"filled-selection\" collapsible code={`<Select variant=\"filled\">\n  <MenuItem value={10}>Ten</MenuItem>\n  <MenuItem value={20}>Twenty</MenuItem>\n  <MenuItem value={30}>Thirty</MenuItem>\n</Select>`} />\n</div>\n\n<h3>Standard</h3>\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <BasicSelectCodeDemo variant=\"standard\" />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"standard-selection\" collapsible code={`<Select variant=\"standard\">\n  <MenuItem value={10}>Ten</MenuItem>\n  <MenuItem value={20}>Twenty</MenuItem>\n  <MenuItem value={30}>Thirty</MenuItem>\n</Select>`} />\n</div>\n\n<a id=\"Sizes\">\n  <h2>Sizes</h2>\n</a>\n\n<p>\n  There are 3 size option for the select component: autowidth, small,\n  and fullWidth. Depending on the size of the select, different prop\n  can be passed to the component.\n</p>\n\n<h3>Autowidth</h3>\n<p>\n  An autoWidth option is passed to the component to enable this\n  attribute\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <AutoWidthSelectCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"size-auto\" collapsible code={`<Select autoWidth>\n  <MenuItem value={10}>Ten</MenuItem>\n  <MenuItem value={20}>Twenty</MenuItem>\n  <MenuItem value={30}>Thirty</MenuItem>\n</Select>`} />\n</div>\n\n<h3>Small</h3>\n<p>\n  To generate small select, pass a size prop with a value of small\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <BasicSelectCodeDemo size=\"small\" />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"size-small\" collapsible code={`<Select size=\"small\">\n  <MenuItem value={10}>Ten</MenuItem>\n  <MenuItem value={20}>Twenty</MenuItem>\n  <MenuItem value={30}>Thirty</MenuItem>\n</Select>`} />\n</div>\n\n<h3>Full width</h3>\n<p>\n  The select will expand the full width of its parent when passed\n  fullWidth prop\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <FullWidthSelectCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"size-fullwidth\" collapsible code={`<Select fullWidth>\n  <MenuItem value={10}>Ten</MenuItem>\n  <MenuItem value={20}>Twenty</MenuItem>\n  <MenuItem value={30}>Thirty</MenuItem>\n</Select>`} />\n</div>\n\n<a id=\"Customization\">\n  <h2>Customization</h2>\n</a>\n\n<h3>Label</h3>\n<p>\n  To add a label to the select component, wrap it inside a FormControl\n  component. Add an InputLabel component and link it to the select\n  component using the labelId prop. Ensure the label prop in the\n  Select component matches the InputLabel text.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <LabelSelectCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"customize-label\" collapsible code={`<FormControl sx={{ width: \"200px\" }}>\n  <InputLabel id=\"demo-select-label\">Age</InputLabel>\n  <Select\n    labelId=\"demo-select-label\"\n    label=\"Age\"\n  >\n    <MenuItem value={10}>Ten</MenuItem>\n    <MenuItem value={20}>Twenty</MenuItem>\n    <MenuItem value={30}>Thirty</MenuItem>\n  </Select>\n</FormControl>`} />\n</div>\n\n<h3>Helper text</h3>\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <HelperSelectCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"customize-helper-text\" collapsible code={`<FormControl sx={{ width: \"200px\" }}>\n  <Select>\n    <MenuItem value={10}>Ten</MenuItem>\n    <MenuItem value={20}>Twenty</MenuItem>\n    <MenuItem value={30}>Thirty</MenuItem>\n  </Select>\n  <FormHelperText>This is a helper text</FormHelperText>\n</FormControl>`} />\n</div>\n\n<h3>Placeholder</h3>\n<p>\n  To add a placeholder, use the renderValue prop to display a\n  placeholder text when no value is selected.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <PlaceholderSelectCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"customize-placeholder\" collapsible code={`const [selectedAge, setSelectedAge] = React.useState(\"\");\n\n<Select\n  onChange={(e) => setSelectedAge(e.target.value)}\n  renderValue={() => {\n    if (selectedAge == \"\") return <em>Select an age</em>;\n    return selectedAge;\n  }}\n  value={selectedAge}\n  displayEmpty\n>\n  <MenuItem value={10}>Ten</MenuItem>\n  <MenuItem value={20}>Twenty</MenuItem>\n  <MenuItem value={30}>Thirty</MenuItem>\n</Select>`} />\n</div>\n\n<h3>Grouping</h3>\nTo group selection options, use the ListSubheader component to create\nheaders for each group within the dropdown menu. This helps users to\neasily navigate and find the options they need.\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <GroupingSelectCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"customize-grouping\" collapsible code={`<Select>\n  <ListSubheader muiSkipListHighlight>Group 1</ListSubheader>\n  <MenuItem value={10}>Ten</MenuItem>\n  <MenuItem value={20}>Twenty</MenuItem>\n  <ListSubheader muiSkipListHighlight>Group 2</ListSubheader>\n  <MenuItem value={30}>Thirty</MenuItem>\n  <MenuItem value={40}>Fourty</MenuItem>\n  <ListSubheader muiSkipListHighlight>Group 3</ListSubheader>\n  <MenuItem value={50}>Fifty</MenuItem>\n  <MenuItem value={60}>Sixty</MenuItem>\n</Select>`} />\n</div>\n\n<p>\n  Additional props such as error, required, and disabled can be passed\n  to the select component to customize its behavior.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <BehaviorSelectCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"behavior-error-disabled\" collapsible code={`<Select disabled>\n  <MenuItem value={10}>Ten</MenuItem>\n  <MenuItem value={20}>Twenty</MenuItem>\n  <MenuItem value={30}>Thirty</MenuItem>\n</Select>\n<Select error>\n  <MenuItem value={10}>Ten</MenuItem>\n  <MenuItem value={20}>Twenty</MenuItem>\n  <MenuItem value={30}>Thirty</MenuItem>\n</Select>`} />\n</div>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <RequiredSelectCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"behavior-required\" collapsible code={`<FormControl required>\n  <InputLabel id=\"demo-select-label-outlined\">Age</InputLabel>\n  <Select\n    labelId=\"demo-select-label-outlined\"\n    label=\"Age\"\n  >\n    <MenuItem value={10}>Ten</MenuItem>\n    <MenuItem value={20}>Twenty</MenuItem>\n    <MenuItem value={30}>Thirty</MenuItem>\n  </Select>\n</FormControl>`} />\n<p>\n  <strong>NOTE:</strong>\n</p>\n<p>\n  When the select component is marked as required, an asterisk is\n  added to the label to indicate this to the user. It is recommended\n  to use this feature in conjunction with the label for better\n  clarity.\n</p>\n</div>\n\n<a id=\"Multi-select\">\n  <h2>Multi-select</h2>\n</a>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <MultipleSelectCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"multiselect\" collapsible code={`const [multipleAges, setMultipleAges] = React.useState([]);\nconst handleMultiplSelect = (event) => {\n  let agesList = event.target.value;\n  setMultipleAges(agesList);\n};\n\n<Select\n  multiple\n  input={<OutlinedInput label=\"Name\" />}\n  value={multipleAges}\n  onChange={handleMultiplSelect}\n>\n  <MenuItem value={10}>Ten</MenuItem>\n  <MenuItem value={20}>Twenty</MenuItem>\n  <MenuItem value={30}>Thirty</MenuItem>\n</Select>`} />\n</div>\n","frontmatter":{"title":"Select Code","description":"Select component is a dropdown menu for selecting an option from a list."}}},"pageContext":{"slug":"/projects/sistent/components/select/code","componentName":"select","availablePages":["code","overview","guidance"],"frontmatter":{"title":"Select Code","component":"select","description":"Select component is a dropdown menu for selecting an option from a list."}}},"staticQueryHashes":["4152005505","934084603"],"slicesMap":{}}