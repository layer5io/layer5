{"componentChunkName":"component---src-templates-sistent-component-js-content-file-path-src-collections-sistent-components-pagination-code-mdx","path":"/projects/sistent/components/pagination/code","result":{"data":{"mdx":{"body":"\nimport { useState } from \"react\";\nimport { Pagination } from \"@sistent/sistent\";\n\nexport const BasicPaginationCodeDemo = () => {\n  const [currentPage, setCurrentPage] = useState(1);\n  const handlePageChange = (event, value) => setCurrentPage(value);\n  return (\n    <Pagination count={10} page={currentPage} onChange={handlePageChange} />\n  );\n};\n\n<a id=\"Basic Pagination\">\n  <h3>Basic Pagination</h3>\n</a>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <BasicPaginationCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"basic-pagination\" collapsible code={`\n    <Pagination \n      count={10} \n      page={1} \n      onChange={(event, page) => handleChange(page)} \n    />\n  `} />\n</div>\n\n<a id=\"Sizes\">\n  <h3>Pagination Sizes</h3>\n</a>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <div style={{ display: \"flex\", flexDirection: \"column\", gap: \"1rem\" }}>\n        <Pagination size=\"small\" count={10} />\n        <Pagination size=\"medium\" count={10} />\n        <Pagination size=\"large\" count={10} />\n      </div>\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"pagination-sizes\" collapsible code={`\n    <Pagination size=\"small\" count={10} />\n    <Pagination size=\"medium\" count={10} />\n    <Pagination size=\"large\" count={10} />\n  `} />\n</div>\n\n<a id=\"Styling\">\n  <h3>Custom Styling</h3>\n</a>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <Pagination count={10} color=\"primary\" variant=\"outlined\" shape=\"rounded\" />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"styled-pagination\" collapsible code={`\n    <Pagination\n      count={10}\n      color=\"primary\"\n      variant=\"outlined\"\n      shape=\"rounded\"\n    />\n  `} />\n</div>\n\n<a id=\"Outline\">\n  <h3>Pagination with Outline</h3>\n</a>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <Pagination count={10} variant=\"outlined\" color=\"secondary\" />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"pagination-outline\" collapsible code={`\n    <Pagination\n      count={10}\n      variant=\"outlined\"\n      color=\"secondary\"\n    />\n  `} />\n</div>\n","frontmatter":{"title":"Pagination Code","description":"The Pagination component helps users navigate through multiple pages of content. It provides a clear interface for moving between pages and understanding the current position within a larger dataset."}}},"pageContext":{"slug":"/projects/sistent/components/pagination/code","componentName":"pagination","availablePages":["guidance","code","overview"],"frontmatter":{"title":"Pagination Code","component":"pagination","description":"The Pagination component helps users navigate through multiple pages of content. It provides a clear interface for moving between pages and understanding the current position within a larger dataset."}}},"staticQueryHashes":["4152005505","934084603"],"slicesMap":{}}