{"componentChunkName":"component---src-templates-sistent-component-js-content-file-path-src-collections-sistent-components-tooltip-code-mdx","path":"/projects/sistent/components/tooltip/code","result":{"data":{"mdx":{"body":"\n\nimport { Button, Box, Grid, CustomTooltip } from \"@sistent/sistent\";\n\nexport const codes = [\n  `<CustomTooltip title=\"Submit\">\n  <span>\n    <Button variant=\"contained\" label=\"Submit\" size=\"medium\" />\n  </span>\n</CustomTooltip>`,\n  `<Box sx={{ width: 500 }}>\n  <Grid container sx={{ justifyContent: \"center\" }}>\n    <Grid item>\n      <CustomTooltip title=\"Add\" placement=\"top-start\">\n        <span>\n          <Button>top-start</Button>\n        </span>\n      </CustomTooltip>\n      <CustomTooltip title=\"Add\" placement=\"top\">\n        <span>\n          <Button>top</Button>\n        </span>\n      </CustomTooltip>\n      <CustomTooltip title=\"Add\" placement=\"top-end\">\n        <span>\n          <Button>top-end</Button>\n        </span>\n      </CustomTooltip>\n    </Grid>\n  </Grid>\n  <Grid container sx={{ justifyContent: \"center\" }}>\n    <Grid item xs={6}>\n      <CustomTooltip title=\"Add\" placement=\"left-start\">\n        <span>\n          <Button>left-start</Button>\n        </span>\n      </CustomTooltip>\n      <br />\n      <CustomTooltip title=\"Add\" placement=\"left\">\n        <span>\n          <Button>left</Button>\n        </span>\n      </CustomTooltip>\n      <br />\n      <CustomTooltip title=\"Add\" placement=\"left-end\">\n        <span>\n          <Button>left-end</Button>\n        </span>\n      </CustomTooltip>\n    </Grid>\n    <Grid\n      item\n      container\n      xs={6}\n      direction=\"column\"\n      sx={{ alignItems: \"flex-end\" }}\n    >\n      <Grid item>\n        <CustomTooltip title=\"Add\" placement=\"right-start\">\n          <span>\n            <Button>right-start</Button>\n          </span>\n        </CustomTooltip>\n      </Grid>\n      <Grid item>\n        <CustomTooltip title=\"Add\" placement=\"right\">\n          <span>\n            <Button>right</Button>\n          </span>\n        </CustomTooltip>\n      </Grid>\n      <Grid item>\n        <CustomTooltip title=\"Add\" placement=\"right-end\">\n          <span>\n            <Button>right-end</Button>\n          </span>\n        </CustomTooltip>\n      </Grid>\n    </Grid>\n  </Grid>\n  <Grid container sx={{ justifyContent: \"center\" }}>\n    <Grid item>\n      <CustomTooltip title=\"Add\" placement=\"bottom-start\">\n        <span>\n          <Button>bottom-start</Button>\n        </span>\n      </CustomTooltip>\n      <CustomTooltip title=\"Add\" placement=\"bottom\">\n        <span>\n          <Button>bottom</Button>\n        </span>\n      </CustomTooltip>\n      <CustomTooltip title=\"Add\" placement=\"bottom-end\">\n        <span>\n          <Button>bottom-end</Button>\n        </span>\n      </CustomTooltip>\n    </Grid>\n  </Grid>\n</Box>`,\n  `<CustomTooltip\n  title=\"Add\"\n  slotProps={{\n    popper: {\n      modifiers: [\n        {\n          name: \"offset\",\n          options: {\n            offset: [0, -14],\n          },\n        },\n      ],\n    },\n  }}\n>\n  <span>\n    <Button variant=\"contained\" size=\"medium\">  \n      Offset\n    </Button>\n  </span>\n</CustomTooltip>`,\n  `<CustomTooltip title=\"Add\" variant=\"standard\">\n  <span>\n    <Button variant=\"contained\" size=\"medium\">\n      standard\n    </Button>\n  </span>\n</CustomTooltip>\n<CustomTooltip title=\"Add\" variant=\"small\">\n  <span>\n    <Button variant=\"contained\" size=\"medium\">\n      small\n    </Button>\n  </span>\n</CustomTooltip>`,\n  `<CustomTooltip title=\"Follow Cursor\" followCursor>\n  <span>\n    <Button variant=\"contained\" size=\"medium\">\n      Button\n    </Button>\n  </span>\n</CustomTooltip>`,\n  `<CustomTooltip title=\"Add\" enterDelay={500} leaveDelay={200}>\n  <span>\n    <Button variant=\"text\" size=\"medium\">\n      [500MS, 200MS]\n    </Button>\n  </span>\n</CustomTooltip>`,\n];\n\nexport const BasicTooltipDemo = () => (\n  <CustomTooltip title=\"Submit\">\n    <span>\n      <Button variant=\"contained\" label=\"Submit\" size=\"medium\" />\n    </span>\n  </CustomTooltip>\n);\n\nexport const PositionedTooltipDemo = () => (\n  <Box sx={{ width: 500 }}>\n    <Grid container sx={{ justifyContent: \"center\" }}>\n      <Grid item>\n        <CustomTooltip title=\"Add\" placement=\"top-start\">\n          <span>\n            <Button>top-start</Button>\n          </span>\n        </CustomTooltip>\n        <CustomTooltip title=\"Add\" placement=\"top\">\n          <span>\n            <Button>top</Button>\n          </span>\n        </CustomTooltip>\n        <CustomTooltip title=\"Add\" placement=\"top-end\">\n          <span>\n            <Button>top-end</Button>\n          </span>\n        </CustomTooltip>\n      </Grid>\n    </Grid>\n    <Grid container sx={{ justifyContent: \"center\" }}>\n      <Grid item xs={6}>\n        <CustomTooltip title=\"Add\" placement=\"left-start\">\n          <span>\n            <Button>left-start</Button>\n          </span>\n        </CustomTooltip>\n        <br />\n        <CustomTooltip title=\"Add\" placement=\"left\">\n          <span>\n            <Button>left</Button>\n          </span>\n        </CustomTooltip>\n        <br />\n        <CustomTooltip title=\"Add\" placement=\"left-end\">\n          <span>\n            <Button>left-end</Button>\n          </span>\n        </CustomTooltip>\n      </Grid>\n      <Grid\n        item\n        container\n        xs={6}\n        direction=\"column\"\n        sx={{ alignItems: \"flex-end\" }}\n      >\n        <Grid item>\n          <CustomTooltip title=\"Add\" placement=\"right-start\">\n            <span>\n              <Button>right-start</Button>\n            </span>\n          </CustomTooltip>\n        </Grid>\n        <Grid item>\n          <CustomTooltip title=\"Add\" placement=\"right\">\n            <span>\n              <Button>right</Button>\n            </span>\n          </CustomTooltip>\n        </Grid>\n        <Grid item>\n          <CustomTooltip title=\"Add\" placement=\"right-end\">\n            <span>\n              <Button>right-end</Button>\n            </span>\n          </CustomTooltip>\n        </Grid>\n      </Grid>\n    </Grid>\n    <Grid container sx={{ justifyContent: \"center\" }}>\n      <Grid item>\n        <CustomTooltip title=\"Add\" placement=\"bottom-start\">\n          <span>\n            <Button>bottom-start</Button>\n          </span>\n        </CustomTooltip>\n        <CustomTooltip title=\"Add\" placement=\"bottom\">\n          <span>\n            <Button>bottom</Button>\n          </span>\n        </CustomTooltip>\n        <CustomTooltip title=\"Add\" placement=\"bottom-end\">\n          <span>\n            <Button>bottom-end</Button>\n          </span>\n        </CustomTooltip>\n      </Grid>\n    </Grid>\n  </Box>\n);\n\nexport const DistanceFromAnchorDemo = () => (\n  <CustomTooltip\n    title=\"Add\"\n    slotProps={{\n      popper: {\n        modifiers: [\n          {\n            name: \"offset\",\n            options: {\n              offset: [0, -14],\n            },\n          },\n        ],\n      },\n    }}\n  >\n    <span>\n      <Button variant=\"contained\" size=\"medium\">\n        Offset\n      </Button>\n    </span>\n  </CustomTooltip>\n);\n\nexport const VariableWidthDemo = () => (\n  <Box\n    sx={{\n      display: \"flex\",\n      \"& > *\": {\n        m: 1,\n      },\n    }}\n  >\n    <CustomTooltip title=\"Add\" variant=\"standard\">\n      <span>\n        <Button variant=\"contained\" size=\"medium\">\n          standard\n        </Button>\n      </span>\n    </CustomTooltip>\n    <CustomTooltip title=\"Add\" variant=\"small\">\n      <span>\n        <Button variant=\"contained\" size=\"medium\">\n          small\n        </Button>\n      </span>\n    </CustomTooltip>\n  </Box>\n);\n\nexport const FollowCursorDemo = () => (\n  <CustomTooltip title=\"Follow Cursor\" followCursor>\n    <span>\n      <Button variant=\"contained\" size=\"medium\">\n        Button\n      </Button>\n    </span>\n  </CustomTooltip>\n);\n\nexport const ShowHideDemo = () => (\n  <CustomTooltip title=\"Add\" enterDelay={500} leaveDelay={200}>\n    <span>\n      <Button variant=\"text\" size=\"medium\">\n        [500MS, 200MS]\n      </Button>\n    </span>\n  </CustomTooltip>\n);\n\n<a id=\"Basic Tooltip\">\n  <h3>Basic Tooltip</h3>\n</a>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <BasicTooltipDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"tooltip-basic\" collapsible code={codes[0]} />\n</div>\n\n<a id=\"Positioned Example\">\n  <h3>Positioned Example</h3>\n</a>\n<p>\n  You can specify the position of the Popper using the `placement` prop. Here's an example of a Tooltip positioned above its anchor:\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <PositionedTooltipDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"tooltip-positioned\" collapsible code={codes[1]} />\n</div>\n\n<a id=\"Distance from anchor\">\n  <h3>Distance from anchor</h3>\n</a>\n<p>\n  To adjust the distance between the tooltip and its anchor, you can use the slotProps prop to modify the offset of the popper.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <DistanceFromAnchorDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"tooltip-distance\" collapsible code={codes[2]} />\n</div>\n\n<a id=\"Variable width\">\n  <h3>Variable width</h3>\n</a>\n<p>\n  The variant prop in Tooltip allows you to control the tooltips size with predefined styles (standard or small). This makes it easier to adjust the tooltip to fit various UI requirements quickly and consistently.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <VariableWidthDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"tooltip-variable-width\" collapsible code={codes[3]} />\n</div>\n\n<a id=\"Follow cursor\">\n  <h3>Follow Cursor</h3>\n</a>\n<p>\n  Tooltips can be configured to follow the cursor, making it easier to read the content.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <FollowCursorDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"tooltip-follow-cursor\" collapsible code={codes[4]} />\n</div>\n\n<a id=\"Showing and hiding\">\n  <h3>Showing and Hiding</h3>\n</a>\n<p>\n  A delay in showing or hiding the tooltip can be added through the `enterDelay` and `leaveDelay` props.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <ShowHideDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"tooltip-show-hide\" collapsible code={codes[5]} />\n</div>\n","frontmatter":{"title":"Tooltip Code","description":"The Tooltip component displays informative text when users hover over, focus on, or tap an element. Tooltips are designed to enhance accessibility and user understanding of interface elements."}}},"pageContext":{"slug":"/projects/sistent/components/tooltip/code","componentName":"tooltip","availablePages":["code","guidance","overview"],"frontmatter":{"title":"Tooltip Code","component":"tooltip","description":"The Tooltip component displays informative text when users hover over, focus on, or tap an element. Tooltips are designed to enhance accessibility and user understanding of interface elements."}}},"staticQueryHashes":["4152005505","934084603"],"slicesMap":{}}