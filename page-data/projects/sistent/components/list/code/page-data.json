{"componentChunkName":"component---src-templates-sistent-component-js-content-file-path-src-collections-sistent-components-list-code-mdx","path":"/projects/sistent/components/list/code","result":{"data":{"mdx":{"body":"\nimport { useState } from \"react\";\nimport { List, ListItem, ListItemText, ListItemIcon, ListItemAvatar, ListItemButton, ListSubheader, Divider, Collapse, Checkbox } from \"@sistent/sistent\";\nimport StarIcon from \"@mui/icons-material/Star\";\nimport CalendarTodayIcon from \"@mui/icons-material/CalendarToday\";\nimport NotificationsIcon from \"@mui/icons-material/Notifications\";\nimport PersonIcon from \"@mui/icons-material/Person\";\nimport EngineeringIcon from \"@mui/icons-material/Engineering\";\nimport ExpandLess from \"@mui/icons-material/ExpandLess\";\nimport ExpandMore from \"@mui/icons-material/ExpandMore\";\n\nexport const NestedListCodeDemo = () => {\n  const [open1, setOpen1] = useState(false);\n  const [open2, setOpen2] = useState(false);\n  const toggleOpen1 = () => setOpen1((prev) => !prev);\n  const toggleOpen2 = () => setOpen2((prev) => !prev);\n  return (\n    <List\n      sx={{ width: \"100%\", maxWidth: 360, padding: 2, bgcolor: \"background.paper\" }}\n      component=\"nav\"\n    >\n      <ListSubheader component=\"div\" id=\"nested-list-subheader\">\n        Layer5 Main Section\n      </ListSubheader>\n      <ListItemButton onClick={toggleOpen1}>\n        <ListItemText primary=\"Layer5 Main Item 1\" />\n        {open1 ? <ExpandLess /> : <ExpandMore />}\n      </ListItemButton>\n      <Collapse in={open1} timeout=\"auto\" unmountOnExit>\n        <List component=\"div\" disablePadding sx={{ pl: 4 }}>\n          <ListItem><ListItemText primary=\"Layer5 Sub Item 1.1\" /></ListItem>\n          <ListItem><ListItemText primary=\"Layer5 Sub Item 1.2\" /></ListItem>\n        </List>\n      </Collapse>\n      <ListItemButton onClick={toggleOpen2}>\n        <ListItemText primary=\"Layer5 Main Item 2\" />\n        {open2 ? <ExpandLess /> : <ExpandMore />}\n      </ListItemButton>\n      <Collapse in={open2} timeout=\"auto\" unmountOnExit>\n        <List component=\"div\" disablePadding sx={{ pl: 4 }}>\n          <ListItem><ListItemText primary=\"Layer5 Sub Item 2.1\" /></ListItem>\n          <ListItem><ListItemText primary=\"Layer5 Sub Item 2.2\" /></ListItem>\n        </List>\n      </Collapse>\n    </List>\n  );\n};\n\nexport const CheckboxListCodeDemo = () => {\n  const [checked, setChecked] = useState([]);\n  const handleToggle = (value) => {\n    setChecked((prevChecked) =>\n      prevChecked.includes(value)\n        ? prevChecked.filter((item) => item !== value)\n        : [...prevChecked, value]\n    );\n  };\n  return (\n    <List sx={{ width: \"100%\", maxWidth: 360 }}>\n      {[0, 1, 2, 3].map((value) => {\n        const labelId = `checkbox-list-label-${value}`;\n        return (\n          <ListItem key={value} disablePadding>\n            <ListItemButton onClick={() => handleToggle(value)} dense>\n              <ListItemIcon>\n                <Checkbox\n                  edge=\"start\"\n                  checked={checked.includes(value)}\n                  tabIndex={-1}\n                  disableRipple\n                  inputProps={{ \"aria-labelledby\": labelId }}\n                />\n              </ListItemIcon>\n              <ListItemText id={labelId} primary={`Layer5 Sistent Item ${value + 1}`} />\n            </ListItemButton>\n          </ListItem>\n        );\n      })}\n    </List>\n  );\n};\n\n<a id=\"Simple List\">\n  <h3>Simple List</h3>\n</a>\n\nThis is a basic list with plain text items.\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <List>\n        <ListItem><ListItemText primary=\"Layer5 Sistent Item 1\" /></ListItem>\n        <ListItem><ListItemText primary=\"Layer5 Sistent Item 2\" /></ListItem>\n        <ListItem><ListItemText primary=\"Layer5 Sistent Item 3\" /></ListItem>\n      </List>\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"simple-list\" collapsible code={`  <List>\n       <ListItem><ListItemText primary=\"Layer5 Sistent 1\" /></ListItem> \n       <ListItem><ListItemText primary=\"Layer5 Sistent 2\" /></ListItem> \n       <ListItem><ListItemText primary=\"Layer5 Sistent 3\" /></ListItem> \n  </List>`} />\n</div>\n\n<a id=\"List With Icons\">\n  <h3>List with Icons</h3>\n</a>\n\nList items can be paired with icons to add visual cues.\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <List>\n        <ListItem>\n          <ListItemIcon><StarIcon /></ListItemIcon>\n          <ListItemText primary=\"Layer5 Sistent Starred\" />\n        </ListItem>\n        <ListItem>\n          <ListItemIcon><CalendarTodayIcon /></ListItemIcon>\n          <ListItemText primary=\"Layer5 Sistent Calendar\" />\n        </ListItem>\n        <ListItem>\n          <ListItemIcon><NotificationsIcon /></ListItemIcon>\n          <ListItemText primary=\"Layer5 Sistent Notification\" />\n        </ListItem>\n      </List>\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"icon-list\" collapsible code={`  <List>\n       <ListItem><ListItemIcon><StarIcon /></ListItemIcon><ListItemText primary=\"Layer5 Sistent Starred\" /></ListItem>\n       <ListItem><ListItemIcon><CalendarTodayIcon /></ListItemIcon><ListItemText primary=\"Layer5 Sistent Calender\" /></ListItem>\n       <ListItem><ListItemIcon><NotificationsIcon /></ListItemIcon><ListItemText primary=\"Layer5 Sistent Notification\" /></ListItem>\n  </List>`} />\n</div>\n\n<a id=\"List With Avatars\">\n  <h3>List with Avatars</h3>\n</a>\n\nUse avatars for list items representing people or entities.\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <List>\n        <ListItem><ListItemAvatar><PersonIcon /></ListItemAvatar><ListItemText primary=\"Layer5 Sistent User 1\" /></ListItem>\n        <ListItem><ListItemAvatar><EngineeringIcon /></ListItemAvatar><ListItemText primary=\"Layer5 Sistent User 2\" /></ListItem>\n        <ListItem><ListItemAvatar><PersonIcon /></ListItemAvatar><ListItemText primary=\"Layer5 Sistent User 3\" /></ListItem>\n      </List>\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"avatar-list\" collapsible code={`  <List>\n       <ListItem><ListItemAvatar><PersonIcon /></ListItemAvatar><ListItemText primary=\"Layer5 Sistent User 1\" /></ListItem>\n       <ListItem><ListItemAvatar><EngineeringIcon /></ListItemAvatar><ListItemText primary=\"Layer5 Sistent User 2\" /></ListItem>\n       <ListItem><ListItemAvatar><PersonIcon /></ListItemAvatar><ListItemText primary=\"Layer5 Sistent User 3\" /></ListItem>\n  </List>`} />\n</div>\n\n<a id=\"List With Subheader\">\n  <h3>List with Subheader</h3>\n</a>\n\nOrganize list items under different subheaders for better grouping.\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <List>\n        <ListSubheader>Section 1</ListSubheader>\n        <ListItem><ListItemText primary=\"Layer5 Sistent Item A\" /></ListItem>\n        <ListItem><ListItemText primary=\"Layer5 Sistent Item B\" /></ListItem>\n        <Divider />\n        <ListSubheader>Section 2</ListSubheader>\n        <ListItem><ListItemText primary=\"Layer5 Sistent Item C\" /></ListItem>\n        <ListItem><ListItemText primary=\"Layer5 Sistent Item D\" /></ListItem>\n      </List>\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"subheader-list\" collapsible code={`  <List>\n       <ListSubheader>Section 1</ListSubheader>\n       <ListItem><ListItemText primary=\"Layer5 Sistent A\" /></ListItem>\n       <ListItem><ListItemText primary=\"Layer5 Sistent B\" /></ListItem>      \n       <ListSubheader>Section 2</ListSubheader>\n       <ListItem><ListItemText primary=\"Layer5 Sistent C\" /></ListItem>\n       <ListItem><ListItemText primary=\"Layer5 Sistent D\" /></ListItem>\n  </List>`} />\n</div>\n\n<a id=\"List With ActionButtons\">\n  <h3>List with Action Buttons</h3>\n</a>\n\nLists can also have action buttons for added interactivity.\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <List>\n        <ListItemButton onClick={() => {}}> Layer5 Sistent Action Item 1</ListItemButton>\n        <ListItemButton onClick={() => {}}>Layer5 Sistent Action Item 2</ListItemButton>\n      </List>\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"button-list\" collapsible code={`  <List>\n       <ListItemButton onClick={() => {}}> Layer5 Sistent Action 1</ListItemButton>\n       <ListItemButton onClick={() => {}}>Layer5 Sistent Action 2</ListItemButton>\n  </List>`} />\n</div>\n\n<a id=\"Nested List\">\n  <h3>List with Nested Items</h3>\n</a>\n\nLists can also be nested to represent hierarchical structures.\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <NestedListCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"nested-list\" collapsible code={`  <List sx={{ width: \"100%\", maxWidth: 360, padding: 2, bgcolor: \"background.paper\" }} component=\"nav\">\n       <ListSubheader component=\"div\" id=\"nested-list-subheader\"> Layer5 Main Section </ListSubheader>\n       <ListItemButton onClick={toggleOpen1}> \n           <ListItemText primary=\"Layer5 Main Item 1\" />\n           {open1 ? <ExpandLess /> : <ExpandMore />} \n       </ListItemButton>\n       <Collapse in={open1} timeout=\"auto\" unmountOnExit>\n         <List component=\"div\" disablePadding sx={{ pl: 4 }}>\n           <ListItem> <ListItemText primary=\"Layer5 Sub Item 1.1\" /></ListItem>\n           <ListItem> <ListItemText primary=\"Layer5 Sub Item 1.2\" /></ListItem>\n         </List>\n       </Collapse>\n       <ListItemButton onClick={toggleOpen2}> \n         <ListItemText primary=\"Layer5 Main Item 2\" />\n         {open2 ? <ExpandLess /> : <ExpandMore />}  \n       </ListItemButton>\n       <Collapse in={open2} timeout=\"auto\" unmountOnExit>\n         <List component=\"div\" disablePadding sx={{ pl: 4 }}>\n           <ListItem><ListItemText primary=\"Layer5 Sub Item 2.1\" /></ListItem>\n           <ListItem><ListItemText primary=\"Layer5 Sub Item 2.2\" /></ListItem>\n         </List>\n       </Collapse>\n  </List>`} />\n</div>\n\n<a id=\"List Control With Checkboxes\">\n  <h3>List Control with Checkboxes</h3>\n</a>\n\nAdd checkboxes to list items for selection. A checkbox can either be a primary action or a secondary action.\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <CheckboxListCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"checkbox-list\" collapsible code={`  <List sx={{ width: \"100%\", maxWidth: 360 }}>\n       {[0, 1, 2, 3].map((value) => {\n         const labelId = \"checkbox-list-label-\" + value;\n         return (\n           <ListItem key={value} disablePadding>\n             <ListItemButton onClick={() => handleToggle(value)} dense>\n               <ListItemIcon>\n                 <Checkbox\n                   edge=\"start\"\n                   checked={checked.includes(value)}\n                   tabIndex={-1}\n                   disableRipple\n                   inputProps={{ \"aria-labelledby\": labelId }}\n                 />\n               </ListItemIcon>\n               <ListItemText id={labelId} primary={\"Layer5 Sistent Item \" + (value + 1)} />\n             </ListItemButton>\n           </ListItem>\n         );\n       })}\n  </List>`} />\n</div>\n","frontmatter":{"title":"List Code","description":"The List component displays a list of items in a structured and accessible manner. Variants include simple lists, lists with icons, lists with avatars, and lists with action buttons."}}},"pageContext":{"slug":"/projects/sistent/components/list/code","componentName":"list","availablePages":["code","guidance","overview"],"frontmatter":{"title":"List Code","component":"list","description":"The List component displays a list of items in a structured and accessible manner. Variants include simple lists, lists with icons, lists with avatars, and lists with action buttons."}}},"staticQueryHashes":["4152005505","934084603"],"slicesMap":{}}