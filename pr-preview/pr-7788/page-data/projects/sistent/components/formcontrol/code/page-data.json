{"componentChunkName":"component---src-templates-sistent-component-js-content-file-path-src-collections-sistent-components-formcontrol-code-mdx","path":"/projects/sistent/components/formcontrol/code","result":{"data":{"mdx":{"body":"\nimport { useState } from \"react\";\nimport { FormControl, InputLabel, MenuItem, Select, TextField, Box } from \"@sistent/sistent\";\n\nexport const BasicFormControlCodeDemo = () => {\n  return (\n    <FormControl sx={{ width: \"200px\" }}>\n      <InputLabel id=\"demo-form-control-label\">Name</InputLabel>\n      <Select\n        labelId=\"demo-form-control-label\"\n        id=\"demo-form-control\"\n        label=\"Name\"\n        MenuProps={{ disableScrollLock: true, marginThreshold: null }}\n      >\n        <MenuItem value=\"john\">John</MenuItem>\n        <MenuItem value=\"jane\">Jane</MenuItem>\n        <MenuItem value=\"bob\">Bob</MenuItem>\n      </Select>\n    </FormControl>\n  );\n};\n\nexport const FullWidthFormControlCodeDemo = () => {\n  return (\n    <FormControl fullWidth>\n      <TextField\n        label=\"Full Width Input\"\n        variant=\"outlined\"\n        placeholder=\"This input takes full width\"\n      />\n    </FormControl>\n  );\n};\n\nexport const RequiredFormControlCodeDemo = () => {\n  return (\n    <FormControl sx={{ width: \"200px\" }} required>\n      <InputLabel id=\"demo-required-label\">Required Field</InputLabel>\n      <Select\n        labelId=\"demo-required-label\"\n        id=\"demo-required\"\n        label=\"Required Field\"\n        MenuProps={{ disableScrollLock: true, marginThreshold: null }}\n      >\n        <MenuItem value=\"option1\">Option 1</MenuItem>\n        <MenuItem value=\"option2\">Option 2</MenuItem>\n      </Select>\n    </FormControl>\n  );\n};\n\nexport const ErrorFormControlCodeDemo = () => {\n  return (\n    <FormControl sx={{ width: \"200px\" }} error>\n      <InputLabel id=\"demo-error-label\">Email</InputLabel>\n      <Select\n        labelId=\"demo-error-label\"\n        id=\"demo-error\"\n        label=\"Email\"\n        MenuProps={{ disableScrollLock: true, marginThreshold: null }}\n      >\n        <MenuItem value=\"email1\">email1@example.com</MenuItem>\n        <MenuItem value=\"email2\">email2@example.com</MenuItem>\n      </Select>\n    </FormControl>\n  );\n};\n\nexport const DisabledFormControlCodeDemo = () => {\n  return (\n    <FormControl sx={{ width: \"200px\" }} disabled>\n      <InputLabel id=\"demo-disabled-label\">Disabled Field</InputLabel>\n      <Select\n        labelId=\"demo-disabled-label\"\n        id=\"demo-disabled\"\n        label=\"Disabled Field\"\n        MenuProps={{ disableScrollLock: true, marginThreshold: null }}\n      >\n        <MenuItem value=\"option1\">Option 1</MenuItem>\n        <MenuItem value=\"option2\">Option 2</MenuItem>\n      </Select>\n    </FormControl>\n  );\n};\n\nexport const SizeFormControlCodeDemo = () => {\n  return (\n    <Box sx={{ display: \"flex\", flexDirection: \"column\", gap: 2 }}>\n      <FormControl sx={{ width: \"200px\" }} size=\"small\">\n        <InputLabel id=\"demo-small-label\">Small Size</InputLabel>\n        <Select\n          labelId=\"demo-small-label\"\n          id=\"demo-small\"\n          label=\"Small Size\"\n          MenuProps={{ disableScrollLock: true, marginThreshold: null }}\n        >\n          <MenuItem value=\"small\">Small Option</MenuItem>\n        </Select>\n      </FormControl>\n\n      <FormControl sx={{ width: \"200px\" }} size=\"medium\">\n        <InputLabel id=\"demo-medium-label\">Medium Size</InputLabel>\n        <Select\n          labelId=\"demo-medium-label\"\n          id=\"demo-medium\"\n          label=\"Medium Size\"\n          MenuProps={{ disableScrollLock: true, marginThreshold: null }}\n        >\n          <MenuItem value=\"medium\">Medium Option</MenuItem>\n        </Select>\n      </FormControl>\n    </Box>\n  );\n};\n\n<a id=\"Basic Usage\">\n  <h2>Basic Usage</h2>\n</a>\n<p>\n  The most common use case for FormControl is wrapping form inputs with labels.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <BasicFormControlCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"basic-form-control\" collapsible code={`<FormControl sx={{ width: \"200px\" }}>\n  <InputLabel id=\"demo-form-control-label\">Name</InputLabel>\n  <Select\n    labelId=\"demo-form-control-label\"\n    id=\"demo-form-control\"\n    label=\"Name\"\n  >\n    <MenuItem value=\"john\">John</MenuItem>\n    <MenuItem value=\"jane\">Jane</MenuItem>\n    <MenuItem value=\"bob\">Bob</MenuItem>\n  </Select>\n</FormControl>`} />\n</div>\n\n<a id=\"Full Width\">\n  <h2>Full Width</h2>\n</a>\n<p>\n  Use the <code>fullWidth</code> prop to make the FormControl take the full width of its container.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <FullWidthFormControlCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"full-width-form-control\" collapsible code={`<FormControl fullWidth>\n  <TextField\n    label=\"Full Width Input\"\n    variant=\"outlined\"\n    placeholder=\"This input takes full width\"\n  />\n</FormControl>`} />\n</div>\n\n<a id=\"Required Fields\">\n  <h2>Required Fields</h2>\n</a>\n<p>\n  Add the <code>required</code> prop to indicate that a field must be filled.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <RequiredFormControlCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"required-form-control\" collapsible code={`<FormControl sx={{ width: \"200px\" }} required>\n  <InputLabel id=\"demo-required-label\">Required Field</InputLabel>\n  <Select\n    labelId=\"demo-required-label\"\n    id=\"demo-required\"\n    label=\"Required Field\"\n  >\n    <MenuItem value=\"option1\">Option 1</MenuItem>\n    <MenuItem value=\"option2\">Option 2</MenuItem>\n  </Select>\n</FormControl>`} />\n</div>\n\n<a id=\"Error State\">\n  <h2>Error State</h2>\n</a>\n<p>\n  Use the <code>error</code> prop to indicate validation errors.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <ErrorFormControlCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"error-form-control\" collapsible code={`<FormControl sx={{ width: \"200px\" }} error>\n  <InputLabel id=\"demo-error-label\">Email</InputLabel>\n  <Select\n    labelId=\"demo-error-label\"\n    id=\"demo-error\"\n    label=\"Email\"\n  >\n    <MenuItem value=\"email1\">email1@example.com</MenuItem>\n    <MenuItem value=\"email2\">email2@example.com</MenuItem>\n  </Select>\n</FormControl>`} />\n</div>\n\n<a id=\"Disabled State\">\n  <h2>Disabled State</h2>\n</a>\n<p>\n  The <code>disabled</code> prop prevents user interaction with the form control.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <DisabledFormControlCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"disabled-form-control\" collapsible code={`<FormControl sx={{ width: \"200px\" }} disabled>\n  <InputLabel id=\"demo-disabled-label\">Disabled Field</InputLabel>\n  <Select\n    labelId=\"demo-disabled-label\"\n    id=\"demo-disabled\"\n    label=\"Disabled Field\"\n  >\n    <MenuItem value=\"option1\">Option 1</MenuItem>\n    <MenuItem value=\"option2\">Option 2</MenuItem>\n  </Select>\n</FormControl>`} />\n</div>\n\n<a id=\"Size Variants\">\n  <h2>Size Variants</h2>\n</a>\n<p>\n  FormControl supports <code>small</code> and <code>medium</code> sizes.\n</p>\n\n<div className=\"showcase\">\n  <div className=\"items\">\n    <ThemeWrapper>\n      <SizeFormControlCodeDemo />\n    </ThemeWrapper>\n  </div>\n  <CodeBlock name=\"size-form-control\" collapsible code={`<FormControl sx={{ width: \"200px\" }} size=\"small\">\n  <InputLabel id=\"demo-small-label\">Small Size</InputLabel>\n  <Select\n    labelId=\"demo-small-label\"\n    id=\"demo-small\"\n    label=\"Small Size\"\n  >\n    <MenuItem value=\"small\">Small Option</MenuItem>\n  </Select>\n</FormControl>\n\n<FormControl sx={{ width: \"200px\" }} size=\"medium\">\n  <InputLabel id=\"demo-medium-label\">Medium Size</InputLabel>\n  <Select\n    labelId=\"demo-medium-label\"\n    id=\"demo-medium\"\n    label=\"Medium Size\"\n  >\n    <MenuItem value=\"medium\">Medium Option</MenuItem>\n  </Select>\n</FormControl>`} />\n</div>","frontmatter":{"title":"Form Control Code","description":"FormControl provides context such as filled/focused/error/required for form inputs. It's a fundamental building block for creating consistent form layouts."}}},"pageContext":{"slug":"/projects/sistent/components/formcontrol/code","componentName":"formcontrol","availablePages":["code","guidance","overview"],"frontmatter":{"title":"Form Control Code","component":"formcontrol","description":"FormControl provides context such as filled/focused/error/required for form inputs. It's a fundamental building block for creating consistent form layouts."}}},"staticQueryHashes":["4152005505","805582494","934084603"],"slicesMap":{}}